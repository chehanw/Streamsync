rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    // True only for authenticated users accessing their own data.
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // True if the signed-in user has a document in /Researchers/{uid}.
    // That document is created manually via Firebase Console or Admin SDK —
    // never by the mobile app — so patients can never grant themselves this role.
    function isResearcher() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/Researchers/$(request.auth.uid));
    }

    // ── Researcher registry ───────────────────────────────────────────────────
    // Researchers can read their own entry (lets the dashboard confirm the role).
    // Only Admin SDK / Firebase Console can create or modify entries here.

    match /Researchers/{researcherId} {
      allow read:  if isOwner(researcherId) || isResearcher();
      allow write: if false; // Admin SDK only — never writable by a client
    }

    // ── Dashboard config (researcher read-only, Admin SDK write) ─────────────
    // Stores hkTestUid, studyId, researcherProfile — never written by clients.

    match /config/{docId} {
      allow read:  if isResearcher();
      allow write: if false; // Admin SDK / Firebase Console only
    }

    // ── Audit log (researcher write, no client reads) ─────────────────────────
    // Export events written here; queryable only via Admin SDK or Console.

    match /audit_log/{logId} {
      allow create: if isResearcher();
      allow read, update, delete: if false;
    }

    // ── Patient registry (researcher-managed, used by dashboard) ─────────────
    // Researchers read/write this collection to register study participants.
    // Patients have no access to it.

    match /patients/{patientId} {
      allow read, write: if isResearcher();
    }

    // ── User profiles ─────────────────────────────────────────────────────────

    match /users/{uid} {
      // Owner reads their own profile; researchers read any profile.
      allow read: if isOwner(uid) || isResearcher();

      // Only allow writing the Throne device-link fields to the root profile
      // document. All other app data lives in named subcollections below.
      // Researchers cannot overwrite patient profile documents.
      allow write: if isOwner(uid)
        && request.resource.data.keys().hasOnly(['throneUserId', 'throneUserIdSetAt']);

      // ── Throne data (written by Cloud Function, read by owner + researcher) ─
      // Demo account (CUziuLyPtDNO2IvSbsifXPKrNEk2) is readable by any
      // authenticated user so all testers share the same uroflow data.

      match /throne_sessions/{sessionId} {
        allow read:  if isOwner(uid) || isResearcher()
                     || (request.auth != null && uid == 'CUziuLyPtDNO2IvSbsifXPKrNEk2');
        allow write: if false; // Cloud Function (Admin SDK) only
      }

      match /throne_metrics/{metricId} {
        allow read:  if isOwner(uid) || isResearcher()
                     || (request.auth != null && uid == 'CUziuLyPtDNO2IvSbsifXPKrNEk2');
        allow write: if false; // Cloud Function (Admin SDK) only
      }

      match /throne_sync/{docId} {
        allow read:  if isOwner(uid) || isResearcher()
                     || (request.auth != null && uid == 'CUziuLyPtDNO2IvSbsifXPKrNEk2');
        allow write: if false; // Cloud Function (Admin SDK) only
      }

      // ── HealthKit data (written by device, read by owner + researcher) ──────

      match /hk_heartRate/{sampleId} {
        allow read:       if isOwner(uid) || isResearcher();
        allow write:      if isOwner(uid);
      }

      match /hk_stepCount/{sampleId} {
        allow read:       if isOwner(uid) || isResearcher();
        allow write:      if isOwner(uid);
      }

      match /hk_sleepAnalysis/{sampleId} {
        allow read:       if isOwner(uid) || isResearcher();
        allow write:      if isOwner(uid);
      }

      match /hk_heartRateVariabilitySDNN/{sampleId} {
        allow read:       if isOwner(uid) || isResearcher();
        allow write:      if isOwner(uid);
      }

      match /hk_sync/{metricType} {
        allow read, write: if isOwner(uid);
      }

      // ── Throne sync requests (written by app, triggers Cloud Function) ───────

      match /sync_requests/{docId} {
        allow read, write: if isOwner(uid);
      }

      // ── Clinical data ────────────────────────────────────────────────────────

      match /clinical_notes/{noteId} {
        allow read:  if isOwner(uid) || isResearcher();
        allow write: if isOwner(uid);
      }

      match /medical_history_prefill/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /medical_history/{docId} {
        allow read:  if isOwner(uid) || isResearcher();
        allow write: if isOwner(uid);
      }

      // ── Study metadata ───────────────────────────────────────────────────────

      match /surgery_date/{docId} {
        allow read:  if isOwner(uid) || isResearcher();
        allow write: if isOwner(uid);
      }

      match /consent_response/{docId} {
        allow read:  if isOwner(uid) || isResearcher();
        allow write: if isOwner(uid);
      }

      match /study_timeline/{docId} {
        allow read:  if isOwner(uid) || isResearcher();
        allow write: if isOwner(uid);
      }

      // ── IPSS scores — baseline + post-op follow-ups (1, 2, 3 months) ─────────

      match /ipss_scores/{period} {
        allow read:  if isOwner(uid) || isResearcher();
        allow write: if isOwner(uid);
      }
    }

    // ── Throne ingestion collections (Cloud Function / Admin SDK only) ────────

    match /throneSync/{studyId} {
      allow read, write: if false;
    }

    // Researchers can enumerate enrolled users via throneUserMap.
    // Cloud Function still has exclusive write access via Admin SDK.
    match /throneUserMap/{throneUserId} {
      allow read:  if isResearcher();
      allow write: if false; // Cloud Function (Admin SDK) only
    }
  }
}
