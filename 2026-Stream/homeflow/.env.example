# Backend Configuration
EXPO_PUBLIC_BACKEND_TYPE=local

# LLM Configuration
# Set to "true" to route LLM calls through Firebase Cloud Function (production).
# Set to "false" to call OpenAI directly from the client (development only).
EXPO_PUBLIC_USE_BACKEND_LLM=false
EXPO_PUBLIC_BACKEND_LLM_URL=
EXPO_PUBLIC_FUNCTIONS_BASE_URL=
EXPO_PUBLIC_SMART_HEALTH_SYSTEMS_JSON=
EXPO_PUBLIC_EPIC_CLIENT_ID=

# LLM API Keys (development only — must NOT ship in production bundle)
EXPO_PUBLIC_OPENAI_API_KEY=
